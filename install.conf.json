[
  {
    "defaults": {
      "link": {
        "relink": true,
        "create": true
      }
    }
  },
  {
    "clean": ["~/.config"]
  },
  {
    "link": {
      "~/.config/nvim": "nvim",
      "~/.config/tmux": "tmux",
      "~/.config/git": "git",
      "~/.config/ghostty": "ghostty",
      "~/.config/opencode": "opencode",
      "~/.config/mise": "mise"
    }
  },
  {
    "shell": [
      {
        "command": "if ! command -v mise &>/dev/null; then echo 'Installing mise...'; curl -fsSL https://mise.run | sh; fi",
        "description": "Installing mise if missing"
      },
      {
        "command": "export PATH=\"$HOME/.local/bin:$PATH\" && echo 'Installing tools via mise...' && mise install --yes",
        "description": "Installing tools configured via mise"
      }
    ]
  }
]

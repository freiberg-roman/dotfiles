[
  {
    "defaults": {
      "link": {
        "relink": true,
        "create": true,
        "force": true
      }
    }
  },
  {
    "clean": [
      "~/.config"
    ]
  },
  {
    "link": {
      "~/.config/nvim": "nvim",
      "~/.config/tmux": "tmux",
      "~/.config/git": "git",
      "~/.config/ghostty": "ghostty",
      "~/.config/mise": "mise",
      "~/.config/nushell": "nushell",
      "~/.pi/agent/extensions/replace-99.ts": "pi/extensions/replace-99.ts"
    }
  },
  {
    "shell": [
      {
        "command": "export PATH=\"$HOME/.local/bin:$PATH\" && echo 'Installing tools via mise...' && mise install --yes",
        "description": "Installing tools configured via mise"
      }
    ]
  }
]
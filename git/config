[core]
    editor = nvim

[rerere]
    enabled = true

[rebase]
    updateRefs = true

[alias]
    graph = log --oneline --graph --decorate --all
    st = status -s
    unstage = reset HEAD --

[worktree]
    unlock = true
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
